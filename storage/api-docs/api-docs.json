{
    "openapi": "3.0.0",
    "info": {
        "title": "Learning Resources API",
        "description": "API documentation for the Learning Resources React Frontend",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Local API Server"
        }
    ],
    "paths": {
        "/api/resources": {
            "get": {
                "tags": [
                    "Resources"
                ],
                "summary": "Get list of all learning resources",
                "operationId": "0a6700b47dcce2d2d071b3000f20aa60",
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "id": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "title": {
                                                "type": "string",
                                                "example": "Advanced Calculus Video"
                                            },
                                            "ai_summary": {
                                                "type": "string",
                                                "example": "Most users found this highly comprehensive."
                                            }
                                        },
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Resources"
                ],
                "summary": "Submit a new learning resource",
                "operationId": "e889331b6f6c163c83371a691ee6b787",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "title",
                                    "url_or_isbn"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "Intro to React"
                                    },
                                    "url_or_isbn": {
                                        "type": "string",
                                        "example": "https://youtube.com/watch?v=123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Resource created successfully"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/reviews/{review_id}/like": {
            "post": {
                "tags": [
                    "Likes"
                ],
                "summary": "Toggle a like on a review",
                "operationId": "f38eed904d92544ddd95185f13802162",
                "parameters": [
                    {
                        "name": "review_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Like toggled successfully"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/reports": {
            "post": {
                "tags": [
                    "Reports"
                ],
                "summary": "Report a resource or review to admins",
                "operationId": "318de4ef8123b483320dc9dbb45b6a43",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "reason"
                                ],
                                "properties": {
                                    "learning_resource_id": {
                                        "type": "integer",
                                        "nullable": true
                                    },
                                    "review_id": {
                                        "type": "integer",
                                        "nullable": true
                                    },
                                    "reason": {
                                        "type": "string",
                                        "example": "Invalid YouTube link"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Report submitted successfully"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/reviews": {
            "post": {
                "tags": [
                    "Reviews"
                ],
                "summary": "Leave a review on a learning resource",
                "operationId": "154c71f5f72b459d998f5ea451bd4c96",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "learning_resource_id",
                                    "rating",
                                    "content"
                                ],
                                "properties": {
                                    "learning_resource_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "rating": {
                                        "description": "Must be between 1 and 5",
                                        "type": "integer",
                                        "example": 4
                                    },
                                    "content": {
                                        "type": "string",
                                        "example": "Great explanation of integrals!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Review saved successfully"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "tags": [
        {
            "name": "Resources",
            "description": "Resources"
        },
        {
            "name": "Likes",
            "description": "Likes"
        },
        {
            "name": "Reports",
            "description": "Reports"
        },
        {
            "name": "Reviews",
            "description": "Reviews"
        }
    ]
}